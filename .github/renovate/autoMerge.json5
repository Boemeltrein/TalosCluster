{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      matchUpdateTypes: ["major"],
      automerge: false
    },
    {
      matchUpdateTypes: ["minor"],
      matchPackageNames: [
        "!/siderolabs/",
        "!/flux-operator/",
        "!/flux-instance/",        
        "!/longhorn/",
        "!/cilium/"
      ],
      automerge: true,
      addLabels: ["automerge"]  
    },
    {
      matchUpdateTypes: ["patch"],
      matchPackageNames: [
        "!/siderolabs/",
        "!/flux-operator/",
        "!/flux-instance/"           
      ],
      automerge: true,
      addLabels: ["automerge"]
    },
    {
      matchUpdateTypes: ["digest"],
      automerge: true,
      addLabels: ["automerge"]
    },
    {
      matchUpdateTypes: ["pin", "pinDigest"],
      automerge: true,
      addLabels: ["automerge"]
    }
  ]
}
